@model IEnumerable<Reciclajejuego.AppMVC.Models.Residuo>

@{
    ViewData["Title"] = "Residuos";
}

<style>
    .main-container {
        min-height: 100vh;
    }

    .card-custom {
        background: #e1f5fe;
        border-radius: 30px;
        padding: 35px;
        max-width: 1200px;
        width: 100%;
        margin: auto;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }

    .titulo {
        background: linear-gradient(135deg, #667eea, #5b86e5);
        color: white;
        padding: 10px 30px;
        border-radius: 50px;
        font-size: 1.8rem;
        margin-bottom: 20px;
        display: inline-block;
    }

    .btn-crear {
        background: linear-gradient(135deg, #43e97b, #38c172);
        color: white;
        border-radius: 25px;
        padding: 10px 20px;
        text-decoration: none;
        font-weight: bold;
    }

    .btn-editar {
        background: linear-gradient(135deg, #f6a623, #f7971e);
        color: white;
        border-radius: 15px;
    }

    .btn-detalles {
        background: linear-gradient(135deg, #36d1dc, #5b86e5);
        color: white;
        border-radius: 15px;
    }

    .btn-eliminar {
        background: linear-gradient(135deg, #ff5f6d, #ff7eb3);
        color: white;
        border-radius: 15px;
    }

    .table-wrapper {
        overflow-x: auto;
    }
</style>

<div class="container-fluid px-4 main-container d-flex justify-content-center align-items-center">

    <div class="card-custom text-center">

        <!-- 🔹 TÍTULO -->
        <div class="mb-3">
            <span class="titulo">♻️ Gestión de Residuos</span>
        </div>

        <!-- 🔍 FILTRO -->
        <form method="get" class="mb-3">
            <div class="row g-2 justify-content-center">

                <div class="col-md-5">
                    <input type="text" name="buscar"
                           value="@ViewBag.Buscar"
                           class="form-control rounded-pill"
                           placeholder="Buscar residuo..." />
                </div>

                <div class="col-md-2 d-grid">
                    <button type="submit" class="btn btn-primary rounded-pill">
                        Buscar
                    </button>
                </div>

                <div class="col-md-2 d-grid">
                    <a asp-action="Index" class="btn btn-secondary rounded-pill">
                        Limpiar
                    </a>
                </div>

            </div>
        </form>

        <!-- 🔹 BOTÓN CREAR -->
        <div class="mb-4 text-end">
            <a asp-action="Create" class="btn-crear">
                ➕ Nuevo Residuo
            </a>
        </div>

        <!-- 🔹 TABLA -->
        <div class="table-wrapper shadow">
            <table class="table table-hover align-middle mb-0 text-center">

                <thead>
                    <tr>
                        <th>Imagen</th>
                        <th>Nombre</th>
                        <th>Descripción</th>
                        <th>Puntos</th>
                        <th>Contenedor</th>
                        <th>Acciones</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>

                            <!-- IMAGEN -->
                            <td>
                                @if (!string.IsNullOrEmpty(item.ImagenUrl))
                                {
                                    <img src="@item.ImagenUrl" class="img-residuo" />
                                }
                                else
                                {
                                    <span class="text-muted">Sin imagen</span>
                                }
                            </td>

                            <!-- DATOS -->
                            <td class="fw-bold">@item.Nombre</td>
                            <td>@item.Descripcion</td>
                            <td>@item.Puntos</td>
                            <td>@item.Contenedor?.TipoReciclaje</td>

                            <!-- ACCIONES -->
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-editar me-1">✏️</a>

                                <a asp-action="Details" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-detalles me-1">🔍</a>

                                <a asp-action="Delete" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-eliminar">🗑️</a>
                            </td>

                        </tr>
                    }
                </tbody>

            </table>
        </div>

    </div>

</div>