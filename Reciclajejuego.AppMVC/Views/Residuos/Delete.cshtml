@model Reciclajejuego.AppMVC.Models.Residuo

@{
    ViewData["Title"] = "Eliminar Residuo";
}

<style>
    .contenedor {
        background: white;
        padding: 35px;
        border-radius: 25px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.15);
        max-width: 750px;
        margin: auto;
        border-top: 6px solid #ff5f6d;
    }

    .titulo {
        background: linear-gradient(135deg, #ff5f6d, #d32f2f);
        color: white;
        padding: 10px 25px;
        border-radius: 50px;
        font-weight: bold;
        display: inline-block;
        margin-bottom: 20px;
    }

    .alerta {
        background-color: #fff3f3;
        border-left: 6px solid #ff5f6d;
        padding: 12px;
        border-radius: 10px;
        font-weight: 600;
        color: #c62828;
        text-align: center;
        margin-bottom: 25px;
    }

    dt {
        font-weight: 600;
        color: #555;
    }

    dd {
        background-color: #f9f9f9;
        padding: 10px 12px;
        border-radius: 10px;
    }

    .btn-eliminar {
        background: linear-gradient(135deg, #ff5f6d, #d32f2f);
        color: white;
        border-radius: 12px;
        padding: 8px 20px;
        border: none;
        font-weight: 600;
    }

    .btn-volver {
        background: linear-gradient(135deg, #43e97b, #38c172);
        color: white;
        border-radius: 12px;
        padding: 8px 20px;
        text-decoration: none;
        font-weight: 600;
    }

        .btn-eliminar:hover,
        .btn-volver:hover {
            transform: scale(1.05);
            color: white;
        }

    .img-delete {
        width: 140px;
        height: 140px;
        object-fit: cover;
        border-radius: 15px;
        display: block;
        margin: 10px auto;
        box-shadow: 0 5px 12px rgba(0,0,0,0.2);
    }
</style>

<div class="container mt-5 d-flex justify-content-center">

    <div class="contenedor text-center">

        <!-- 🔹 TÍTULO -->
        <div class="mb-2">
            <span class="titulo">🗑️ Eliminar Residuo</span>
        </div>

        <!-- 🔹 ALERTA -->
        <div class="alerta">
            ⚠️ Esta acción eliminará el residuo permanentemente.
        </div>

        <dl class="row text-start">

            <dt class="col-sm-4">Nombre</dt>
            <dd class="col-sm-8">@Model.Nombre</dd>

            <dt class="col-sm-4">Descripción</dt>
            <dd class="col-sm-8">@Model.Descripcion</dd>

            <dt class="col-sm-4">Imagen</dt>
            <dd class="col-sm-8 text-center">
                @if (!string.IsNullOrEmpty(Model.ImagenUrl))
                {
                    <img src="@Model.ImagenUrl" class="img-delete" />
                }
                else
                {
                    <span class="text-muted">Sin imagen</span>
                }
            </dd>

            <dt class="col-sm-4">Puntos</dt>
            <dd class="col-sm-8">@Model.Puntos</dd>

            <dt class="col-sm-4">Contenedor</dt>
            <dd class="col-sm-8">
                @Model.Contenedor?.TipoReciclaje
            </dd>

        </dl>

        <!-- 🔹 BOTONES -->
        <form asp-action="Delete" class="mt-4">
            <input type="hidden" asp-for="Id" />

            <div class="d-flex justify-content-between">
                <a asp-action="Index" class="btn-volver">⬅ Cancelar</a>
                <button type="submit" class="btn-eliminar">🗑 Eliminar</button>
            </div>
        </form>

    </div>

</div>