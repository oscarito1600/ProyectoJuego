@model Reciclajejuego.AppMVC.Models.Residuo

@{
    ViewData["Title"] = "Eliminar Residuo";
}

<style>
    body {
        background: linear-gradient(135deg, #ffebee, #ffcdd2);
    }

    .contenedor {
        background: white;
        padding: 35px;
        border-radius: 18px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        max-width: 750px;
        margin: auto;
        border-top: 6px solid #d32f2f;
    }

    .titulo {
        background: linear-gradient(135deg, #ff5f6d, #b71c1c);
        color: white;
        padding: 10px 20px;
        border-radius: 50px;
        font-weight: bold;
        text-align: center;
        display: block;
        margin-bottom: 20px;
    }

    .alerta {
        background-color: #ffebee;
        border-left: 6px solid #d32f2f;
        padding: 12px;
        border-radius: 10px;
        font-weight: 600;
        color: #b71c1c;
        text-align: center;
        margin-bottom: 20px;
    }

    dt {
        font-weight: 600;
        color: #2e7d32;
    }

    dd {
        background-color: #f1f8e9;
        padding: 8px 12px;
        border-radius: 8px;
    }

    .btn-eliminar {
        background: linear-gradient(135deg, #ff5f6d, #d32f2f);
        color: white;
        padding: 8px 18px;
        border-radius: 10px;
        border: none;
        font-weight: 600;
    }

    .btn-volver {
        background: linear-gradient(135deg, #43e97b, #38c172);
        color: white;
        padding: 8px 18px;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 600;
    }

    .img-delete {
        width: 140px;
        height: 140px;
        object-fit: cover;
        border-radius: 12px;
        border: 2px solid #ccc;
        display: block;
        margin: 10px auto;
    }
</style>

<div class="container mt-5">
    <div class="contenedor">

        <!-- TÍTULO -->
        <span class="titulo">🗑️ Eliminar Residuo</span>

        <!-- ALERTA -->
        <div class="alerta">
            ⚠️ ¿Estás seguro de que deseas eliminar este residuo? Esta acción no se puede deshacer.
        </div>

        <dl class="row">

            <!-- NOMBRE -->
            <dt class="col-sm-4">Nombre</dt>
            <dd class="col-sm-8">@Model.Nombre</dd>

            <!-- DESCRIPCIÓN -->
            <dt class="col-sm-4">Descripción</dt>
            <dd class="col-sm-8">@Model.Descripcion</dd>

            <!-- IMAGEN -->
            <dt class="col-sm-4">Imagen</dt>
            <dd class="col-sm-8 text-center">
                @if (!string.IsNullOrEmpty(Model.ImagenUrl))
                {
                    <img src="@Model.ImagenUrl" class="img-delete" />
                }
                else
                {
                    <span>Sin imagen</span>
                }
            </dd>

            <!-- PUNTOS -->
            <dt class="col-sm-4">Puntos</dt>
            <dd class="col-sm-8">@Model.Puntos</dd>

            <!-- CONTENEDOR -->
            <dt class="col-sm-4">Contenedor</dt>
            <dd class="col-sm-8">
                @Model.Contenedor?.TipoReciclaje
            </dd>

        </dl>

        <!-- BOTONES -->
        <form asp-action="Delete" class="mt-4">
            <input type="hidden" asp-for="Id" />

            <div class="d-flex justify-content-between">
                <a asp-action="Index" class="btn-volver">⬅ Cancelar</a>
                <button type="submit" class="btn-eliminar">🗑 Confirmar Eliminación</button>
            </div>
        </form>

    </div>
</div>