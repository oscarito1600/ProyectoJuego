@model Reciclajejuego.AppMVC.Models.Residuo

@{
    ViewData["Title"] = "Eliminar Residuo";
}

<style>
    .main-container {
        min-height: 100vh;
    }

    .card-custom {
        background: #e1f5fe;
        border-radius: 30px;
        padding: 35px;
        max-width: 700px;
        width: 100%;
        margin: auto;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }

    .titulo {
        background: linear-gradient(135deg, #ff4d4d, #ff4d4d);
        color: white;
        padding: 12px;
        border-radius: 50px;
        text-align: center;
        font-weight: bold;
        margin-bottom: 20px;
        font-size: 1.5rem;
    }

    .alerta {
        background: #ffe5e5;
        color: #c62828;
        padding: 15px;
        border-radius: 20px;
        text-align: center;
        font-weight: bold;
        margin-bottom: 20px;
    }

    .detalle-box {
        background: white;
        border-radius: 20px;
        padding: 25px;
        margin-bottom: 25px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        text-align: center;
    }

    .detalle-label {
        color: #5b86e5;
        font-size: 1rem;
        display: block;
        margin-bottom: 5px;
    }

    .detalle-valor {
        font-size: 1.6rem;
        font-weight: bold;
        color: #333;
    }

    .botones {
        display: flex;
        gap: 10px;
    }

    .btn-eliminar {
        background: linear-gradient(135deg, #ff4d4d, #ff4d4d);
        color: white;
        border-radius: 25px;
        padding: 12px;
        width: 50%;
        border: none;
        font-weight: bold;
        transition: 0.3s;
    }

    .btn-volver {
        background: linear-gradient(135deg, #90a4ae, #607d8b);
        color: white;
        border-radius: 25px;
        padding: 12px;
        width: 50%;
        text-align: center;
        text-decoration: none;
        font-weight: bold;
        transition: 0.3s;
    }

        .btn-eliminar:hover,
        .btn-volver:hover {
            transform: scale(1.03);
            color: white;
        }
</style>

<div class="container mt-5 d-flex justify-content-center">

    <div class="contenedor text-center">

        <!-- 🔹 TÍTULO -->
        <div class="mb-2">
            <span class="titulo">🗑️ Eliminar Residuo</span>
        </div>

        <!-- 🔹 ALERTA -->
        <div class="alerta">
            ⚠️ Esta acción eliminará el residuo permanentemente.
        </div>

        <dl class="row text-start">

            <dt class="col-sm-4">Nombre</dt>
            <dd class="col-sm-8">@Model.Nombre</dd>

            <dt class="col-sm-4">Descripción</dt>
            <dd class="col-sm-8">@Model.Descripcion</dd>

            <dt class="col-sm-4">Imagen</dt>
            <dd class="col-sm-8 text-center">
                @if (!string.IsNullOrEmpty(Model.ImagenUrl))
                {
                    <img src="@Model.ImagenUrl" class="img-delete" />
                }
                else
                {
                    <span class="text-muted">Sin imagen</span>
                }
            </dd>

            <dt class="col-sm-4">Puntos</dt>
            <dd class="col-sm-8">@Model.Puntos</dd>

            <dt class="col-sm-4">Contenedor</dt>
            <dd class="col-sm-8">
                @Model.Contenedor?.TipoReciclaje
            </dd>

        </dl>

        <!-- 🔹 BOTONES -->
        <form asp-action="Delete" class="mt-4">
            <input type="hidden" asp-for="Id" />

            <div class="d-flex justify-content-between">
                <a asp-action="Index" class="btn-volver">⬅ Cancelar</a>
                <button type="submit" class="btn-eliminar">🗑 Eliminar</button>
            </div>
        </form>

    </div>

</div>