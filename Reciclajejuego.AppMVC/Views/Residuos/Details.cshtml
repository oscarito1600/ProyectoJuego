@model Reciclajejuego.AppMVC.Models.Residuo

@{
    ViewData["Title"] = "Detalles Residuo";
}

<style>
    body {
        background: linear-gradient(135deg, #e0f7fa, #b2dfdb);
    }

    .contenedor {
        background: white;
        padding: 35px;
        border-radius: 18px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        max-width: 750px;
        margin: auto;
    }

    .titulo {
        color: #00695c;
        font-weight: bold;
        text-align: center;
    }

    dt {
        font-weight: 600;
        color: #00695c;
    }

    dd {
        background-color: #e0f2f1;
        padding: 8px 12px;
        border-radius: 8px;
    }

    .badge-puntos {
        background-color: #43a047;
        color: white;
        padding: 6px 14px;
        border-radius: 20px;
        font-weight: bold;
    }

    .btn-editar {
        background-color: #0288d1;
        color: white;
        padding: 8px 18px;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 600;
        transition: 0.3s;
    }

        .btn-editar:hover {
            background-color: #01579b;
            color: white;
        }

    .btn-volver {
        background-color: #43a047;
        color: white;
        padding: 8px 18px;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 600;
        transition: 0.3s;
    }

        .btn-volver:hover {
            background-color: #2e7d32;
            color: white;
        }
</style>

<div class="container mt-5">
    <div class="contenedor">

        <h2 class="titulo mb-4">🗑️ Detalles del Residuo</h2>

        <dl class="row">

            <dt class="col-sm-4">
                @Html.DisplayNameFor(model => model.Nombre)
            </dt>
            <dd class="col-sm-8">
                @Html.DisplayFor(model => model.Nombre)
            </dd>

            <dt class="col-sm-4">
                @Html.DisplayNameFor(model => model.Descripcion)
            </dt>
            <dd class="col-sm-8">
                @Html.DisplayFor(model => model.Descripcion)
            </dd>

            <dt class="col-sm-4">
                @Html.DisplayNameFor(model => model.Imagen)
            </dt>
            <dd class="col-sm-8">
                @Html.DisplayFor(model => model.Imagen)
            </dd>

            <dt class="col-sm-4">
                @Html.DisplayNameFor(model => model.Puntos)
            </dt>
            <dd class="col-sm-8">
                <span class="badge-puntos">
                    @Html.DisplayFor(model => model.Puntos)
                </span>
            </dd>

            <dt class="col-sm-4">
                @Html.DisplayNameFor(model => model.Contenedor)
            </dt>
            <dd class="col-sm-8">
                @Html.DisplayFor(model => model.Contenedor.ContenedorId)
            </dd>

        </dl>

        <div class="d-flex justify-content-between mt-4">
            <a asp-action="Index" class="btn-volver">⬅ Volver</a>
            <a asp-action="Edit" asp-route-id="@Model?.ResiduoId" class="btn-editar">✏️ Editar</a>
        </div>

    </div>
</div>
