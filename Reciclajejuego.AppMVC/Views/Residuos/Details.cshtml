@model Reciclajejuego.AppMVC.Models.Residuo

@{
    ViewData["Title"] = "Detalles Residuo";
}

<style>
    body {
        background: linear-gradient(135deg, #e0f7fa, #b2dfdb);
    }

    .contenedor {
        background: white;
        padding: 35px;
        border-radius: 18px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        max-width: 750px;
        margin: auto;
    }

    .titulo {
        background: linear-gradient(135deg, #36d1dc, #5b86e5);
        color: white;
        padding: 10px 20px;
        border-radius: 50px;
        font-weight: bold;
        text-align: center;
        display: block;
        margin-bottom: 20px;
    }

    dt {
        font-weight: 600;
        color: #00695c;
    }

    dd {
        background-color: #e0f2f1;
        padding: 8px 12px;
        border-radius: 8px;
    }

    .badge-puntos {
        background: linear-gradient(135deg, #43e97b, #38c172);
        color: white;
        padding: 6px 14px;
        border-radius: 20px;
        font-weight: bold;
    }

    .btn-editar {
        background: linear-gradient(135deg, #f6a623, #f7971e);
        color: white;
        padding: 8px 18px;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 600;
    }

    .btn-volver {
        background: linear-gradient(135deg, #ff5f6d, #ff7eb3);
        color: white;
        padding: 8px 18px;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 600;
    }

    .img-detalle {
        width: 180px;
        height: 180px;
        object-fit: cover;
        border-radius: 12px;
        border: 2px solid #ccc;
        display: block;
        margin: 10px auto;
    }
</style>

<div class="container mt-5">
    <div class="contenedor">

        <!-- TÍTULO -->
        <span class="titulo">🗑️ Detalles del Residuo</span>

        <dl class="row">

            <!-- NOMBRE -->
            <dt class="col-sm-4">Nombre</dt>
            <dd class="col-sm-8">@Model.Nombre</dd>

            <!-- DESCRIPCIÓN -->
            <dt class="col-sm-4">Descripción</dt>
            <dd class="col-sm-8">@Model.Descripcion</dd>

            <!-- IMAGEN -->
            <dt class="col-sm-4">Imagen</dt>
            <dd class="col-sm-8 text-center">
                @if (!string.IsNullOrEmpty(Model.ImagenUrl))
                {
                    <img src="@Model.ImagenUrl" class="img-detalle" />
                }
                else
                {
                    <span>Sin imagen</span>
                }
            </dd>

            <!-- PUNTOS -->
            <dt class="col-sm-4">Puntos</dt>
            <dd class="col-sm-8">
                <span class="badge-puntos">@Model.Puntos</span>
            </dd>

            <!-- CONTENEDOR -->
            <dt class="col-sm-4">Contenedor</dt>
            <dd class="col-sm-8">
                @Model.Contenedor?.TipoReciclaje
            </dd>

        </dl>

        <!-- BOTONES -->
        <div class="d-flex justify-content-between mt-4">
            <a asp-action="Index" class="btn-volver">⬅ Volver</a>
            <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn-editar">✏️ Editar</a>
        </div>

    </div>
</div>