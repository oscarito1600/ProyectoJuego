@model Reciclajejuego.AppMVC.Models.Residuo

@{
    ViewData["Title"] = "Crear Residuo";
}

<style>
    body {
        background: linear-gradient(135deg, #e8f5e9, #c8e6c9);
    }

    .contenedor {
        background: white;
        padding: 35px;
        border-radius: 18px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        max-width: 650px;
        margin: auto;
    }

    .titulo {
        color: #2e7d32;
        font-weight: bold;
        text-align: center;
    }

    label {
        font-weight: 600;
        color: #2e7d32;
    }

    .form-control {
        border-radius: 10px;
        border: 1px solid #81c784;
    }

        .form-control:focus {
            border-color: #2e7d32;
            box-shadow: 0 0 6px rgba(46,125,50,0.4);
        }

    .btn-crear {
        background-color: #43a047;
        color: white;
        padding: 8px 18px;
        border-radius: 10px;
        border: none;
        font-weight: 600;
        transition: 0.3s;
    }

        .btn-crear:hover {
            background-color: #1b5e20;
        }

    .btn-volver {
        background-color: #0288d1;
        color: white;
        padding: 8px 18px;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 600;
        transition: 0.3s;
    }

        .btn-volver:hover {
            background-color: #01579b;
            color: white;
        }
</style>

<div class="container mt-5">
    <div class="contenedor">

        <h2 class="titulo mb-4">🌱 Registrar Nuevo Residuo</h2>

        <!-- IMPORTANTE: enctype agregado -->
        <form asp-action="Create" enctype="multipart/form-data">

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Nombre"></label>
                <input asp-for="Nombre" class="form-control" />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Descripcion"></label>
                <input asp-for="Descripcion" class="form-control" />
                <span asp-validation-for="Descripcion" class="text-danger"></span>
            </div>

            <!-- NUEVO INPUT FILE -->
            <div class="mb-3">
                <label>Imagen</label>
                <input type="file" name="archivoImagen" class="form-control" accept="image/*" />
                <span asp-validation-for="Imagen" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ContenedorId"></label>
                <select asp-for="ContenedorId" class="form-control" asp-items="ViewBag.ContenedorId"></select>
                <span asp-validation-for="ContenedorId" class="text-danger"></span>
            </div>

            <div class="d-flex justify-content-between mt-4">
                <a asp-action="Index" class="btn-volver">⬅ Volver</a>
                <input type="submit" value="♻️ Crear Residuo" class="btn-crear" />
            </div>

        </form>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}