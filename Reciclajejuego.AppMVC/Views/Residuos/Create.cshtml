@model Reciclajejuego.AppMVC.Models.Residuo

@{
    ViewData["Title"] = "Crear Residuo";
}

<style>
    .contenedor {
        background: white;
        padding: 35px;
        border-radius: 25px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.15);
        max-width: 650px;
        margin: auto;
    }

    .titulo {
        background: linear-gradient(135deg, #36d1dc, #5b86e5);
        color: white;
        padding: 12px;
        border-radius: 50px;
        text-align: center;
        font-weight: bold;
        margin-bottom: 25px;
        font-size: 1.5rem;
    }

    .form-control {
        border-radius: 12px;
    }

    .btn-crear {
        background: linear-gradient(135deg, #43e97b, #38c172);
        color: white;
        border-radius: 12px;
        padding: 8px 20px;
        border: none;
    }

    .btn-volver {
        background: linear-gradient(135deg, #ff5f6d, #ff7eb3);
        color: white;
        border-radius: 12px;
        padding: 8px 20px;
        text-decoration: none;
    }

    .img-preview {
        width: 120px;
        height: 120px;
        object-fit: cover;
        border-radius: 15px;
        margin-top: 10px;
        display: none;
    }
</style>

<div class="container mt-5 d-flex justify-content-center">

    <div class="contenedor text-center">

        <span class="titulo">🌱 Crear Residuo</span>

        <form asp-action="Create" method="post" enctype="multipart/form-data">

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <!-- NOMBRE -->
            <div class="mb-3 text-start">
                <label asp-for="Nombre"></label>
                <input asp-for="Nombre" class="form-control" />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>

            <!-- DESCRIPCIÓN -->
            <div class="mb-3 text-start">
                <label asp-for="Descripcion"></label>
                <input asp-for="Descripcion" class="form-control" />
                <span asp-validation-for="Descripcion" class="text-danger"></span>
            </div>

            <!-- PUNTOS -->
            <div class="mb-3 text-start">
                <label asp-for="Puntos"></label>
                <input asp-for="Puntos" class="form-control" />
            </div>

            <!-- IMAGEN -->
            <div class="mb-3 text-start">
                <label>Imagen</label>
                <input type="file" name="archivoImagen" class="form-control" onchange="previewImagen(event)" />
                <img id="preview" class="img-preview" />
            </div>

            <!-- 🔥 CONTENEDOR (FIX IMPORTANTE) -->
            <div class="mb-3 text-start">
                <label asp-for="ContenedorId"></label>
                <select asp-for="ContenedorId"
                        class="form-control"
                        asp-items="ViewBag.ContenedorId">
                    <option value="">-- Seleccione un contenedor --</option>
                </select>
                <span asp-validation-for="ContenedorId" class="text-danger"></span>
            </div>

            <!-- BOTONES -->
            <div class="d-flex justify-content-between mt-4">
                <a asp-action="Index" class="btn-volver">⬅ Volver</a>
                <button type="submit" class="btn-crear">♻️ Crear</button>
            </div>

        </form>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        function previewImagen(event) {
            const preview = document.getElementById('preview');
            preview.src = URL.createObjectURL(event.target.files[0]);
            preview.style.display = "block";
        }
    </script>
}