@model Reciclajejuego.AppMVC.Models.Residuo

@{
    ViewData["Title"] = "Editar Residuo";
}

<style>
    .contenedor {
        background: white;
        padding: 35px;
        border-radius: 25px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.15);
        max-width: 650px;
        margin: auto;
    }

    .titulo {
        background: linear-gradient(135deg, #36d1dc, #5b86e5);
        color: white;
        padding: 10px 25px;
        border-radius: 50px;
        font-weight: bold;
        text-align: center;
        display: inline-block;
        margin-bottom: 25px;
    }

    label {
        font-weight: 600;
        color: #555;
    }

    .form-control {
        border-radius: 12px;
    }

    .btn-guardar {
        background: linear-gradient(135deg, #43e97b, #38c172);
        color: white;
        border-radius: 12px;
        border: none;
        font-weight: 600;
        padding: 8px 20px;
    }

    .btn-volver {
        background: linear-gradient(135deg, #ff5f6d, #ff7eb3);
        color: white;
        border-radius: 12px;
        text-decoration: none;
        padding: 8px 20px;
        font-weight: 600;
    }

        .btn-guardar:hover,
        .btn-volver:hover {
            transform: scale(1.05);
            color: white;
        }

    .img-preview {
        width: 120px;
        height: 120px;
        object-fit: cover;
        border-radius: 15px;
        margin-top: 10px;
        box-shadow: 0 5px 10px rgba(0,0,0,0.2);
    }
</style>

<div class="container mt-5 d-flex justify-content-center">

    <div class="contenedor text-center">

        <!-- 🔹 TÍTULO -->
        <div class="mb-3">
            <span class="titulo">✏️ Editar Residuo</span>
        </div>

        <form asp-action="Edit" enctype="multipart/form-data">

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="ImagenUrl" />

            <!-- NOMBRE -->
            <div class="mb-3 text-start">
                <label asp-for="Nombre"></label>
                <input asp-for="Nombre" class="form-control" />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>

            <!-- DESCRIPCIÓN -->
            <div class="mb-3 text-start">
                <label asp-for="Descripcion"></label>
                <input asp-for="Descripcion" class="form-control" />
                <span asp-validation-for="Descripcion" class="text-danger"></span>
            </div>

            <!-- PUNTOS -->
            <div class="mb-3 text-start">
                <label asp-for="Puntos"></label>
                <input asp-for="Puntos" class="form-control" />
                <span asp-validation-for="Puntos" class="text-danger"></span>
            </div>

            <!-- CONTENEDOR -->
            <div class="mb-3 text-start">
                <label asp-for="ContenedorId"></label>
                <select asp-for="ContenedorId"
                        class="form-control"
                        asp-items="ViewBag.ContenedorId">
                </select>
                <span asp-validation-for="ContenedorId" class="text-danger"></span>
            </div>

            <!-- IMAGEN -->
            <div class="mb-3 text-start">
                <label>Nueva Imagen</label>
                <input type="file" name="archivoImagen" class="form-control" />

                @if (!string.IsNullOrEmpty(Model.ImagenUrl))
                {
                    <div class="text-center">
                        <img src="@Model.ImagenUrl" class="img-preview" />
                    </div>
                }
            </div>

            <!-- BOTONES -->
            <div class="d-flex justify-content-between mt-4">
                <a asp-action="Index" class="btn-volver">⬅ Volver</a>
                <button type="submit" class="btn-guardar">💾 Guardar</button>
            </div>

        </form>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}