@{
    ViewData["Title"] = "PantallaGuiaDet";
}

<style>

    body {
        background: #f4f6f9;
        font-family: Segoe UI;
    }

    .titulo {
        text-align: center;
        margin-top: 30px;
    }

    .tabla {
        width: 80%;
        margin: auto;
        margin-top: 30px;
        background: white;
        border-radius: 10px;
        box-shadow: 0px 3px 10px rgba(0,0,0,0.1);
        overflow: hidden;
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    th {
        background: #28a745;
        color: white;
        padding: 12px;
    }

    td {
        padding: 12px;
        border-bottom: 1px solid #ddd;
        text-align: center;
    }

    img {
        width: 60px;
    }

    tr:hover {
        background: #f8f9fa;
    }

</style>

<h1 class="titulo">Pantalla Guía Detallada</h1>

<div class="tabla">

    <table>

        <tr>
            <th>Residuo ID</th>
            <th>Nombre</th>
            <th>Descripción</th>
            <th>Imagen</th>
            <th>Contenedor ID</th>
        </tr>

        <tr>
            <td>1</td>
            <td>Botella plástica</td>
            <td>Envase de plástico reciclable</td>
            <td><img src="https://cdn-icons-png.flaticon.com/512/1046/1046857.png"></td>
            <td>1</td>
        </tr>

        <tr>
            <td>2</td>
            <td>Lata</td>
            <td>Lata de aluminio reciclable</td>
            <td><img src="https://cdn-icons-png.flaticon.com/512/3659/3659899.png"></td>
            <td>2</td>
        </tr>

        <tr>
            <td>3</td>
            <td>Papel</td>
            <td>Hojas de papel reciclables</td>
            <td><img src="https://cdn-icons-png.flaticon.com/512/2921/2921822.png"></td>
            <td>3</td>
        </tr>

        <tr>
            <td>4</td>
            <td>Vidrio</td>
            <td>Botella de vidrio reciclable</td>
            <td><img src="https://cdn-icons-png.flaticon.com/512/1046/1046860.png"></td>
            <td>4</td>
        </tr>

    </table>

</div>