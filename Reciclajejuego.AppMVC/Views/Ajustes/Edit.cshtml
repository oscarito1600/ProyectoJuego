@model Reciclajejuego.AppMVC.Models.Ajuste

@{
    ViewData["Title"] = "Editar Ajuste";
}

<style>
    .main-container {
        min-height: 100vh;
    }

    .card-custom {
        background: #e1f5fe;
        border-radius: 30px;
        padding: 35px;
        max-width: 800px;
        width: 100%;
        margin: auto;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }

    .titulo {
        background: linear-gradient(135deg, #36d1dc, #5b86e5);
        color: white;
        padding: 12px;
        border-radius: 50px;
        text-align: center;
        font-weight: bold;
        margin-bottom: 25px;
        font-size: 1.5rem;
    }

    .form-control {
        border-radius: 20px;
        padding: 10px;
    }

        .form-control:focus {
            border-color: #38c172;
            box-shadow: 0 0 5px rgba(56,193,114,0.5);
        }

    .btn-guardar {
        background: linear-gradient(135deg, #43e97b, #38c172);
        color: white;
        border-radius: 25px;
        padding: 12px;
        width: 100%;
        border: none;
        font-weight: bold;
        margin-bottom: 10px;
        transition: 0.3s;
    }

    .btn-volver {
        background: linear-gradient(135deg, #90a4ae, #607d8b);
        color: white;
        border-radius: 25px;
        padding: 12px;
        width: 100%;
        text-align: center;
        text-decoration: none;
        font-weight: bold;
        transition: 0.3s;
    }

        .btn-guardar:hover,
        .btn-volver:hover {
            transform: scale(1.03);
            color: white;
        }
</style>

<div class="container-fluid px-4 main-container d-flex justify-content-center align-items-center">

    <div class="card-custom">

        <!-- TITULO -->
        <div class="titulo">
            ⚙️ Editar Ajuste
        </div>

        <!-- FORM -->
        <form asp-action="Edit">

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <input type="hidden" asp-for="Id" />

            <!-- USUARIO -->
            <div class="mb-3 text-start">
                <label asp-for="UsuarioId" class="form-label fw-bold"></label>
                <select asp-for="UsuarioId" class="form-control" asp-items="ViewBag.UsuarioId"></select>
                <span asp-validation-for="UsuarioId" class="text-danger"></span>
            </div>

            <!-- VOLUMEN GENERAL -->
            <div class="mb-3 text-start">
                <label asp-for="VolumenGeneral" class="form-label fw-bold"></label>
                <input asp-for="VolumenGeneral" class="form-control" />
                <span asp-validation-for="VolumenGeneral" class="text-danger"></span>
            </div>

            <!-- VOLUMEN MUSICA -->
            <div class="mb-3 text-start">
                <label asp-for="VolumenMusica" class="form-label fw-bold"></label>
                <input asp-for="VolumenMusica" class="form-control" />
                <span asp-validation-for="VolumenMusica" class="text-danger"></span>
            </div>

            <!-- VOLUMEN EFECTOS -->
            <div class="mb-3 text-start">
                <label asp-for="VolumenEfectos" class="form-label fw-bold"></label>
                <input asp-for="VolumenEfectos" class="form-control" />
                <span asp-validation-for="VolumenEfectos" class="text-danger"></span>
            </div>

            <!-- BOTÓN -->
            <button type="submit" class="btn-guardar">
                💾 Guardar Cambios
            </button>

            <!-- VOLVER -->
            <a asp-action="Index" class="btn-volver">
                ⬅️ Volver a la lista
            </a>

        </form>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
