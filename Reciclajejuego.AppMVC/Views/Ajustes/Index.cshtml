@model IEnumerable<Reciclajejuego.AppMVC.Models.Ajuste>

@{
    ViewData["Title"] = "Ajustes";
}

<!-- FONDO GENERAL -->
<style>
    body {
        background-color: #4caf50; /* fondo moderno */
    }
</style>

<div class="container py-5">

    <div class="row justify-content-center">
        <div class="col-lg-10">

            <!-- CARD -->
            <div class="card shadow border-0 rounded-4">

                <!-- HEADER -->
                <div class="card-header bg-success text-white d-flex justify-content-between align-items-center rounded-top-4">
                    <h5 class="mb-0 fw-bold">⚙️ Sistema de Ajustes</h5>

                    <a asp-action="Create" class="btn btn-light btn-sm rounded-pill fw-bold">
                        ➕ Nuevo
                    </a>
                </div>

                <!-- BODY -->
                <div class="card-body">

                    <!-- BUSCADOR -->
                    <div class="mb-3">
                        <input type="text" class="form-control rounded-pill" placeholder="🔍 Buscar ajuste..." />
                    </div>

                    <!-- TABLA -->
                    <div class="table-responsive">
                        <table class="table table-hover text-center align-middle">

                            <thead class="table-light">
                                <tr>
                                    <th>🔊 General</th>
                                    <th>🎵 Música</th>
                                    <th>🔔 Efectos</th>
                                    <th>👤 Usuario</th>
                                    <th>⚙️ Acciones</th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>@item.VolumenGeneral</td>
                                        <td>@item.VolumenMusica</td>
                                        <td>@item.VolumenEfectos</td>
                                        <td>@item.Usuario.Id</td>

                                        <td>
                                            <a asp-action="Edit" asp-route-id="@item.Id"
                                                   class="btn btn-outline-warning btn-sm rounded-pill me-1">
                                                ✏️
                                            </a>

                                            <a asp-action="Details" asp-route-id="@item.Id"
                                                   class="btn btn-outline-info btn-sm rounded-pill me-1">
                                                🔍
                                            </a>

                                            <a asp-action="Delete" asp-route-id="@item.Id"
                                                   class="btn btn-outline-danger btn-sm rounded-pill">
                                                🗑️
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>

                        </table>
                    </div>

                </div>

            </div>

        </div>
    </div>

</div>
