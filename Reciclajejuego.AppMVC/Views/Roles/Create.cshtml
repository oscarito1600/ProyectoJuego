@model Reciclajejuego.AppMVC.Models.Rol

@{
    ViewData["Title"] = "Crear Rol";
}

<style>
    .main-container {
        min-height: 100vh;
    }

    .card-custom {
        background: #e1f5fe;
        border-radius: 30px;
        padding: 35px;
        max-width: 700px;
        width: 100%;
        margin: auto;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }

    .titulo {
        background: linear-gradient(135deg, #36d1dc, #5b86e5);
        color: white;
        padding: 12px;
        border-radius: 50px;
        text-align: center;
        font-weight: bold;
        margin-bottom: 25px;
        font-size: 1.5rem;
    }

    .form-control {
        border-radius: 20px;
        padding: 10px;
    }

        .form-control:focus {
            border-color: #38c172;
            box-shadow: 0 0 5px rgba(56,193,114,0.5);
        }

    .btn-guardar {
        background: linear-gradient(135deg, #43e97b, #38c172);
        color: white;
        border-radius: 25px;
        padding: 12px;
        width: 100%;
        border: none;
        font-weight: bold;
        margin-bottom: 10px;
        transition: 0.3s;
    }

    .btn-volver {
        background: linear-gradient(135deg, #90a4ae, #607d8b);
        color: white;
        border-radius: 25px;
        padding: 12px;
        width: 100%;
        text-align: center;
        text-decoration: none;
        font-weight: bold;
        transition: 0.3s;
    }

        .btn-guardar:hover,
        .btn-volver:hover {
            transform: scale(1.03);
            color: white;
        }
</style>

<div class="container-fluid px-4 main-container d-flex justify-content-center align-items-center">

    <div class="card-custom">

        <!-- TITULO -->
        <div class="titulo">
            ➕ Crear Rol
        </div>

        <!-- FORM -->
        <form asp-action="Create">

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3 text-start">
                <label asp-for="Nombre" class="form-label fw-bold">📌 Nombre</label>
                <input asp-for="Nombre" class="form-control" placeholder="Ingrese el nombre del rol" />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>

            <!-- BOTÓN -->
            <button type="submit" class="btn-guardar">
                💾 Guardar Rol
            </button>

            <!-- VOLVER -->
            <a asp-action="Index" class="btn-volver">
                ⬅️ Volver
            </a>

        </form>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}