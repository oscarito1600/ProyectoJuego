@model Reciclajejuego.AppMVC.Models.Rol

@{
    ViewData["Title"] = "Detalles del Rol";
}

<style>
    .main-container {
        min-height: 100vh;
    }

    .card-custom {
        background: #e1f5fe;
        border-radius: 30px;
        padding: 35px;
        max-width: 800px;
        width: 100%;
        margin: auto;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }

    .titulo {
        background: linear-gradient(135deg, #36d1dc, #5b86e5);
        color: white;
        padding: 12px;
        border-radius: 50px;
        text-align: center;
        font-weight: bold;
        margin-bottom: 25px;
        font-size: 1.5rem;
    }

    .detalle-box {
        background: white;
        border-radius: 20px;
        padding: 25px;
        margin-bottom: 25px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        text-align: center;
    }

    .detalle-label {
        color: #5b86e5;
        font-size: 1rem;
        display: block;
        margin-bottom: 5px;
    }

    .detalle-valor {
        font-size: 1.6rem;
        font-weight: bold;
        color: #333;
    }

    .botones {
        display: flex;
        justify-content: space-between;
        gap: 10px;
    }

    .btn-editar {
        background: linear-gradient(135deg, #f6a623, #f7971e);
        color: white;
        border-radius: 25px;
        padding: 12px;
        width: 48%;
        text-decoration: none;
        text-align: center;
    }

    .btn-volver {
        background: linear-gradient(135deg, #90a4ae, #607d8b);
        color: white;
        border-radius: 25px;
        padding: 12px;
        width: 48%;
        text-decoration: none;
        text-align: center;
    }

        .btn-editar:hover,
        .btn-volver:hover {
            opacity: 0.9;
            color: white;
        }
</style>

<div class="container-fluid px-4 main-container d-flex justify-content-center align-items-center">

    <div class="card-custom">

        <!-- TITULO -->
        <div class="titulo">
            📄 Detalles del Rol
        </div>

        <!-- DETALLE -->
        <div class="detalle-box">
            <span class="detalle-label">Nombre</span>
            <span class="detalle-valor">@Model.Nombre</span>
        </div>

        <!-- BOTONES -->
        <div class="botones">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-editar">
                ✏️ Editar
            </a>

            <a asp-action="Index" class="btn-volver">
                ⬅️ Volver
            </a>
        </div>

    </div>

</div>
