@model IEnumerable<Reciclajejuego.AppMVC.Models.Usuario>

@{
    ViewData["Title"] = "Usuarios";
}

<style>
    body {
        background: linear-gradient(135deg, #e8f5e9, #c8e6c9);
    }

    .contenedor {
        background-color: white;
        padding: 30px;
        border-radius: 15px;
        box-shadow: 0 8px 20px rgba(0,0,0,0.1);
    }

    .titulo {
        color: #2e7d32;
        font-weight: bold;
    }

    .btn-verde {
        background-color: #2e7d32;
        color: white;
        border-radius: 8px;
        padding: 6px 12px;
        text-decoration: none;
        transition: 0.3s;
    }

    .btn-verde:hover {
        background-color: #1b5e20;
        color: white;
    }

    .btn-accion {
        padding: 5px 10px;
        border-radius: 6px;
        font-size: 14px;
        text-decoration: none;
        color: white;
        margin: 2px;
        transition: 0.3s;
    }

    .editar { background-color: #388e3c; }
    .detalles { background-color: #43a047; }
    .eliminar { background-color: #c62828; }

    .editar:hover { background-color: #1b5e20; }
    .detalles:hover { background-color: #2e7d32; }
    .eliminar:hover { background-color: #8e0000; }

    table thead {
        background-color: #2e7d32;
        color: white;
    }

    table tbody tr:hover {
        background-color: #f1f8e9;
    }
</style>

<div class="container mt-4">
    <div class="contenedor">

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="titulo">🌱 Gestión de Usuarios</h2>
            <a asp-action="Create" class="btn-verde">➕ Nuevo Usuario</a>
        </div>

        <table class="table table-bordered table-hover text-center align-middle">
            <thead>
                <tr>
                    <th>@Html.DisplayNameFor(model => model.Nombre)</th>
                    <th>@Html.DisplayNameFor(model => model.Correo)</th>
                    <th>@Html.DisplayNameFor(model => model.Contrasena)</th>
                    <th>@Html.DisplayNameFor(model => model.MejoresPuntajes)</th>
                    <th>@Html.DisplayNameFor(model => model.CuentaGoogle)</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@Html.DisplayFor(modelItem => item.Nombre)</td>
                        <td>@Html.DisplayFor(modelItem => item.Correo)</td>
                        <td>@Html.DisplayFor(modelItem => item.Contrasena)</td>
                        <td>
                            <span class="badge bg-success">
                                @Html.DisplayFor(modelItem => item.MejoresPuntajes)
                            </span>
                        </td>
                        <td>@Html.DisplayFor(modelItem => item.CuentaGoogle)</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.UsuarioId" class="btn-accion editar">Editar</a>
                            <a asp-action="Details" asp-route-id="@item.UsuarioId" class="btn-accion detalles">Detalles</a>
                            <a asp-action="Delete" asp-route-id="@item.UsuarioId" class="btn-accion eliminar">Eliminar</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

    </div>
</div>
