@model IEnumerable<Reciclajejuego.AppMVC.Models.Usuarios>

@{
    ViewData["Title"] = "Usuarios";
}

<style>
    .main-container {
        min-height: 100vh;
    }

    .card-custom {
        background: #e1f5fe;
        border-radius: 30px;
        padding: 35px;
        max-width: 1200px;
        width: 100%;
        margin: auto;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }

    .titulo {
        background: linear-gradient(135deg, #36d1dc, #5b86e5);
        color: white;
        padding: 10px 30px;
        border-radius: 50px;
        font-size: 1.8rem;
        margin-bottom: 20px;
        display: inline-block;
    }

    .btn-crear {
        background: linear-gradient(135deg, #43e97b, #38c172);
        color: white;
        border-radius: 25px;
        padding: 10px 20px;
        text-decoration: none;
        font-weight: bold;
    }

    .btn-editar {
        background: linear-gradient(135deg, #f6a623, #f7971e);
        color: white;
        border-radius: 15px;
    }

    .btn-detalles {
        background: linear-gradient(135deg, #36d1dc, #5b86e5);
        color: white;
        border-radius: 15px;
    }

    .btn-eliminar {
        background: linear-gradient(135deg, #ff5f6d, #ff7eb3);
        color: white;
        border-radius: 15px;
    }

    .table-wrapper {
        overflow-x: auto;
    }
</style>

<div class="container-fluid px-5 main-container d-flex justify-content-center align-items-center">

    <div class="card-custom text-center">

        <!-- 🔹 TÍTULO -->
        <div class="mb-3">
            <span class="titulo">👤 Gestión de Usuarios</span>
        </div>

        <!-- 🔹 FILTRO -->
        <form method="get" class="mb-3">
            <div class="row g-2 justify-content-center">

                <div class="col-md-4">
                    <input type="text" name="buscar"
                           class="form-control rounded-pill"
                           placeholder="Buscar usuario..." />
                </div>

                <div class="col-md-2">
                    <select name="top" class="form-select rounded-pill">
                        <option value="5">Top 5</option>
                        <option value="10" selected>Top 10</option>
                        <option value="20">Top 20</option>
                    </select>
                </div>

                <div class="col-md-2 d-grid">
                    <button type="submit" class="btn btn-primary rounded-pill">Filtrar</button>
                </div>

                <div class="col-md-2 d-grid">
                    <a asp-action="Create" class="btn-crear">➕ Crear</a>
                </div>

            </div>
        </form>

        <!-- 🔹 TABLA -->
        <div class="table-wrapper shadow">
            <table class="table table-hover text-center align-middle mb-0">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Correo</th>
                        <th>Rol</th>
                        <th>Estado</th>
                        <th style="width: 300px;">Acciones</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold">@item.Nombre</td>
                            <td>@item.Correo</td>
                            <td>@item.Rol?.Nombre</td>
                            <td>
                                <span class="badge @(item.Estado == 1 ? "bg-success" : "bg-secondary")">
                                    @(item.Estado == 1 ? "Activo" : "Inactivo")
                                </span>
                            </td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-editar me-1">Editar</a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-detalles me-1">Detalles</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-eliminar">Eliminar</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

    </div>

</div>