@model Reciclajejuego.AppMVC.Models.Usuarios

@{
    ViewData["Title"] = "Detalles Usuario";
}

<style>
    .main-container {
        min-height: 100vh;
    }

    .card-custom {
        background: #e1f5fe;
        border-radius: 30px;
        padding: 35px;
        max-width: 800px;
        width: 100%;
        margin: auto;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }

    .titulo {
        background: linear-gradient(135deg, #36d1dc, #5b86e5);
        color: white;
        padding: 12px;
        border-radius: 50px;
        text-align: center;
        font-weight: bold;
        margin-bottom: 25px;
        font-size: 1.5rem;
    }

    .detalle-box {
        background: white;
        border-radius: 20px;
        padding: 25px;
        margin-bottom: 25px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        text-align: center;
    }

    .detalle-label {
        color: #5b86e5;
        font-size: 1rem;
        display: block;
        margin-bottom: 5px;
    }

    .detalle-valor {
        font-size: 1.6rem;
        font-weight: bold;
        color: #333;
    }

    .botones {
        display: flex;
        justify-content: space-between;
        gap: 10px;
    }

    .btn-editar {
        background: linear-gradient(135deg, #f6a623, #f7971e);
        color: white;
        border-radius: 25px;
        padding: 12px;
        width: 48%;
        text-decoration: none;
        text-align: center;
    }

    .btn-volver {
        background: linear-gradient(135deg, #90a4ae, #607d8b);
        color: white;
        border-radius: 25px;
        padding: 12px;
        width: 48%;
        text-decoration: none;
        text-align: center;
    }

        .btn-editar:hover,
        .btn-volver:hover {
            opacity: 0.9;
            color: white;
        }
</style>

<div class="container-fluid main-container d-flex justify-content-center align-items-center">

    <div class="card-custom text-center">

        <!-- 🔹 TÍTULO -->
        <div class="mb-3">
            <span class="titulo">👤 Detalles del Usuario</span>
        </div>

        <!-- 🔹 INFO -->
        <div class="row text-start mb-3">
            <div class="col-4 info-label">Nombre</div>
            <div class="col-8 info-value">@Model.Nombre</div>
        </div>

        <div class="row text-start mb-3">
            <div class="col-4 info-label">Correo</div>
            <div class="col-8 info-value">@Model.Correo</div>
        </div>

        <div class="row text-start mb-3">
            <div class="col-4 info-label">Rol</div>
            <div class="col-8 info-value">@Model.Rol?.Nombre</div>
        </div>

        <div class="row text-start mb-3">
            <div class="col-4 info-label">Cuenta Google</div>
            <div class="col-8 info-value">
                @(Model.EsCuentaGoogle ? "Sí" : "No")
            </div>
        </div>

        <div class="row text-start mb-4">
            <div class="col-4 info-label">Estado</div>
            <div class="col-8">
                <span class="badge @(Model.Estado == 1 ? "bg-success" : "bg-secondary")">
                    @(Model.Estado == 1 ? "Activo" : "Inactivo")
                </span>
            </div>
        </div>

        <!-- 🔹 BOTONES -->
        <div class="d-flex justify-content-between">
            <a asp-action="Index" class="btn-volver">⬅ Volver</a>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-editar">✏️ Editar</a>
        </div>

    </div>

</div>