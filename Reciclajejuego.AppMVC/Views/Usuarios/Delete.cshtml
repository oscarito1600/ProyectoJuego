@model Reciclajejuego.AppMVC.Models.Usuarios

@{
    ViewData["Title"] = "Eliminar Usuario";
}

<style>
    .main-container {
        min-height: 100vh;
    }

    .card-custom {
        background: #ffe6e6;
        border-radius: 30px;
        padding: 35px;
        max-width: 650px;
        width: 100%;
        margin: auto;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }

    .titulo {
        background: linear-gradient(135deg, #ff5f6d, #ff7eb3);
        color: white;
        padding: 10px 30px;
        border-radius: 50px;
        font-size: 1.6rem;
        margin-bottom: 20px;
        display: inline-block;
    }

    .alert-custom {
        background: #ffcccc;
        border-radius: 15px;
        padding: 10px;
        font-weight: bold;
    }

    .info-label {
        font-weight: bold;
        color: #555;
    }

    .info-value {
        background: white;
        padding: 8px 15px;
        border-radius: 15px;
        box-shadow: 0 5px 10px rgba(0,0,0,0.1);
    }

    .btn-eliminar {
        background: linear-gradient(135deg, #ff5f6d, #ff7eb3);
        color: white;
        border-radius: 20px;
        padding: 8px 20px;
        font-weight: bold;
    }

    .btn-volver {
        background: #6c757d;
        color: white;
        border-radius: 20px;
        padding: 8px 20px;
    }
</style>

<div class="container-fluid main-container d-flex justify-content-center align-items-center">

    <div class="card-custom text-center">

        <!-- 🔹 TÍTULO -->
        <div class="mb-3">
            <span class="titulo">🗑️ Eliminar Usuario</span>
        </div>

        <!-- 🔹 ALERTA -->
        <div class="alert-custom text-center mb-4">
            ⚠️ ¿Estás seguro que deseas eliminar este usuario?
        </div>

        <!-- 🔹 INFO -->
        <div class="row text-start mb-3">
            <div class="col-4 info-label">Nombre</div>
            <div class="col-8 info-value">@Model.Nombre</div>
        </div>

        <div class="row text-start mb-3">
            <div class="col-4 info-label">Correo</div>
            <div class="col-8 info-value">@Model.Correo</div>
        </div>

        <div class="row text-start mb-3">
            <div class="col-4 info-label">Rol</div>
            <div class="col-8 info-value">@Model.Rol?.Nombre</div>
        </div>

        <div class="row text-start mb-3">
            <div class="col-4 info-label">Cuenta Google</div>
            <div class="col-8 info-value">
                @(Model.EsCuentaGoogle ? "Sí" : "No")
            </div>
        </div>

        <div class="row text-start mb-4">
            <div class="col-4 info-label">Estado</div>
            <div class="col-8">
                <span class="badge @(Model.Estado == 1 ? "bg-success" : "bg-secondary")">
                    @(Model.Estado == 1 ? "Activo" : "Inactivo")
                </span>
            </div>
        </div>

        <!-- 🔹 FORM -->
        <form asp-action="Delete" class="d-flex justify-content-between mt-3">
            <input type="hidden" asp-for="Id" />

            <a asp-action="Index" class="btn-volver">⬅ Volver</a>

            <input type="submit" value="🗑️ Eliminar" class="btn-eliminar" />
        </form>

    </div>

</div>