@model Reciclajejuego.AppMVC.Models.Usuario

@{
    ViewData["Title"] = "Eliminar Usuario";
}

<style>
    body {
        background: linear-gradient(135deg, #e8f5e9, #c8e6c9);
    }

    .contenedor {
        background-color: white;
        padding: 35px;
        border-radius: 15px;
        box-shadow: 0 8px 20px rgba(0,0,0,0.1);
        max-width: 700px;
        margin: auto;
    }

    .titulo {
        color: #c62828;
        font-weight: bold;
        text-align: center;
    }

    .alerta {
        background-color: #ffebee;
        color: #c62828;
        padding: 12px;
        border-radius: 8px;
        text-align: center;
        font-weight: 600;
        margin-bottom: 20px;
    }

    dt {
        font-weight: 600;
        color: #2e7d32;
    }

    dd {
        background-color: #f1f8e9;
        padding: 8px 12px;
        border-radius: 8px;
    }

    .btn-eliminar {
        background-color: #c62828;
        color: white;
        padding: 8px 15px;
        border-radius: 8px;
        border: none;
        transition: 0.3s;
    }

        .btn-eliminar:hover {
            background-color: #8e0000;
        }

    .btn-volver {
        background-color: #66bb6a;
        color: white;
        padding: 8px 15px;
        border-radius: 8px;
        text-decoration: none;
        transition: 0.3s;
    }

        .btn-volver:hover {
            background-color: #388e3c;
            color: white;
        }
</style>

<div class="container mt-5">
    <div class="contenedor">

        <h2 class="titulo mb-3">🗑️ Eliminar Usuario</h2>

        <div class="alerta">
            ⚠️ ¿Estás seguro que deseas eliminar este usuario?
        </div>

        <dl class="row">
            <dt class="col-sm-4">
                @Html.DisplayNameFor(model => model.Nombre)
            </dt>
            <dd class="col-sm-8">
                @Html.DisplayFor(model => model.Nombre)
            </dd>

            <dt class="col-sm-4">
                @Html.DisplayNameFor(model => model.Correo)
            </dt>
            <dd class="col-sm-8">
                @Html.DisplayFor(model => model.Correo)
            </dd>

            <dt class="col-sm-4">
                @Html.DisplayNameFor(model => model.Contrasena)
            </dt>
            <dd class="col-sm-8">
                @Html.DisplayFor(model => model.Contrasena)
            </dd>

            <dt class="col-sm-4">
                @Html.DisplayNameFor(model => model.MejorPuntaje)
            </dt>
            <dd class="col-sm-8">
                @Html.DisplayFor(model => model.MejorPuntaje)
            </dd>

            <dt class="col-sm-4">
                @Html.DisplayNameFor(model => model.CuentaGoogle)
            </dt>
            <dd class="col-sm-8">
                @Html.DisplayFor(model => model.CuentaGoogle)
            </dd>
        </dl>

        <form asp-action="Delete" class="d-flex justify-content-between mt-4">
            <input type="hidden" asp-for="UsuarioId" />
            <a asp-action="Index" class="btn-volver">⬅ Volver</a>
            <input type="submit" value="🗑️ Confirmar Eliminación" class="btn-eliminar" />
        </form>

    </div>
</div>