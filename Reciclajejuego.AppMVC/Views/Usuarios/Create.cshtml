@model Reciclajejuego.AppMVC.Models.Usuario

@{
    ViewData["Title"] = "Crear Usuario";
}

<style>
    body {
        background: linear-gradient(135deg, #e8f5e9, #c8e6c9);
    }

    .contenedor {
        background-color: white;
        padding: 35px;
        border-radius: 15px;
        box-shadow: 0 8px 20px rgba(0,0,0,0.1);
        max-width: 600px;
        margin: auto;
    }

    .titulo {
        color: #2e7d32;
        font-weight: bold;
        text-align: center;
    }

    .form-control {
        border-radius: 8px;
        border: 1px solid #a5d6a7;
    }

        .form-control:focus {
            border-color: #2e7d32;
            box-shadow: 0 0 5px rgba(46,125,50,0.5);
        }

    label {
        font-weight: 600;
        color: #2e7d32;
    }

    .btn-verde {
        background-color: #2e7d32;
        color: white;
        border-radius: 8px;
        padding: 8px 15px;
        border: none;
        transition: 0.3s;
    }

        .btn-verde:hover {
            background-color: #1b5e20;
        }

    .btn-volver {
        background-color: #66bb6a;
        color: white;
        padding: 8px 15px;
        border-radius: 8px;
        text-decoration: none;
        transition: 0.3s;
    }

        .btn-volver:hover {
            background-color: #388e3c;
            color: white;
        }

    .form-check-input:checked {
        background-color: #2e7d32;
        border-color: #2e7d32;
    }
</style>

<div class="container mt-5">
    <div class="contenedor">

        <h2 class="titulo mb-4">➕ Crear Nuevo Usuario</h2>

        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Nombre"></label>
                <input asp-for="Nombre" class="form-control" />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Correo"></label>
                <input asp-for="Correo" class="form-control" />
                <span asp-validation-for="Correo" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Contrasena"></label>
                <input asp-for="Contrasena" class="form-control" />
                <span asp-validation-for="Contrasena" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="MejorPuntaje"></label>
                <input asp-for="MejorPuntaje" class="form-control" />
                <span asp-validation-for="MejorPuntaje" class="text-danger"></span>
            </div>

            <div class="form-check mb-3">
                <input class="form-check-input" asp-for="CuentaGoogle" />
                <label class="form-check-label" asp-for="CuentaGoogle"></label>
            </div>

            <div class="d-flex justify-content-between">
                <a asp-action="Index" class="btn-volver">⬅ Volver</a>
                <input type="submit" value="💾 Crear Usuario" class="btn-verde" />
            </div>

        </form>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}