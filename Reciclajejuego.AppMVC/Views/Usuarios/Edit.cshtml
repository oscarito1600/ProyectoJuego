@model Reciclajejuego.AppMVC.Models.Usuarios

@{
    ViewData["Title"] = "Editar Usuario";
}

<style>
    .main-container {
        min-height: 100vh;
    }

    .card-custom {
        background: #e1f5fe;
        border-radius: 30px;
        padding: 35px;
        max-width: 700px;
        width: 100%;
        margin: auto;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }

    .titulo {
        background: linear-gradient(135deg, #667eea, #5b86e5);
        color: white;
        padding: 12px;
        border-radius: 50px;
        text-align: center;
        font-weight: bold;
        margin-bottom: 25px;
        font-size: 1.5rem;
    }

    .form-control {
        border-radius: 20px;
        padding: 10px;
    }

        .form-control:focus {
            border-color: #5b86e5;
            box-shadow: 0 0 5px rgba(91,134,229,0.5);
        }

    .btn-guardar {
        background: linear-gradient(135deg, #43e97b, #38c172);
        color: white;
        border-radius: 25px;
        padding: 12px;
        width: 100%;
        border: none;
        font-weight: bold;
        margin-bottom: 10px;
        transition: 0.3s;
    }

        .btn-guardar:hover {
            transform: scale(1.03);
            color: white;
        }

    .btn-volver {
        background: linear-gradient(135deg, #90a4ae, #607d8b);
        color: white;
        border-radius: 25px;
        padding: 12px;
        width: 100%;
        text-align: center;
        display: inline-block;
        text-decoration: none;
        font-weight: bold;
        transition: 0.3s;
    }

        .btn-volver:hover {
            transform: scale(1.03);
            color: white;
        }
</style>

<div class="container-fluid main-container d-flex justify-content-center align-items-center">

    <div class="card-custom">

        <!-- 🔹 TÍTULO -->
        <div class="text-center">
            <span class="titulo">✏️ Editar Usuario</span>
        </div>

        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input type="hidden" asp-for="Id" />

            <!-- NOMBRE -->
            <div class="mb-3">
                <label asp-for="Nombre" class="form-label"></label>
                <input asp-for="Nombre" class="form-control" />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>

            <!-- CORREO -->
            <div class="mb-3">
                <label asp-for="Correo" class="form-label"></label>
                <input asp-for="Correo" class="form-control" />
                <span asp-validation-for="Correo" class="text-danger"></span>
            </div>

            <!-- CONTRASEÑA -->
            <div class="mb-3">
                <label asp-for="Contrasena" class="form-label"></label>
                <input asp-for="Contrasena" type="password" class="form-control" />
                <span asp-validation-for="Contrasena" class="text-danger"></span>
            </div>

            <!-- ROL -->
            <div class="mb-3">
                <label asp-for="RolId" class="form-label">Rol</label>
                <select asp-for="RolId" class="form-select" asp-items="ViewBag.IdRol"></select>
            </div>

            <!-- GOOGLE -->
            <div class="form-check mb-4">
                <input class="form-check-input" asp-for="EsCuentaGoogle" />
                <label class="form-check-label" asp-for="EsCuentaGoogle"></label>
            </div>

            <!-- BOTONES -->
            <div class="d-flex justify-content-between">
                <a asp-action="Index" class="btn-volver">⬅ Volver</a>
                <input type="submit" value="💾 Guardar" class="btn-guardar" />
            </div>

        </form>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}