@model IEnumerable<Reciclajejuego.AppMVC.Models.Juego>

@{
    ViewData["Title"] = "Historial de Partidas";
}

<style>
    /* FONDO */
     body {
        background-color: #2e7d32;
        min-height: 100vh;
        font-family: 'Segoe UI', sans-serif;
    }

    /* CONTENEDOR */
    .main-container {
        min-height: 100vh;
    }


    /* TÍTULO */
    .title-capsule {
        background-color: #0d47a1;
        color: white;
        padding: 10px 40px;
        border-radius: 50px;
        font-size: 2rem;
        font-weight: bold;
        display: inline-block;
    }

    /* BUSCADOR */
    .search-input {
        border-radius: 30px;
        border: 2px solid #0d47a1;
    }

    /* BOTÓN CREAR PARTIDA */
    .btn-crear {
        background-color: #1565c0;
        color: white;
        padding: 10px 25px;
        border-radius: 15px;
        text-decoration: none;
        font-weight: bold;
        float: right;
        margin-bottom: 15px;
        transition: 0.3s;
    }

    .btn-crear:hover { background-color: #0d47a1; color: white; }

    /* TABLA ESTILO IMAGEN */
    .table-wrapper {
        background-color: #e1f5fe;
        border: 3px solid #0288d1;
        border-radius: 20px;
        overflow: hidden;
        clear: both;
    }

    .table thead th {
        background-color: #b3e5fc;
        color: #01579b;
        border-bottom: 2px solid #0288d1;
        padding: 15px;
        text-align: center;
    }

    .table tbody td {
        border-bottom: 1px solid #b3e5fc;
        padding: 15px;
        vertical-align: middle;
        background-color: #ffffff;
    }

    /* BOTONES DE ACCIÓN */
    .btn-edit {
        background-color: #ffa000;
        color: white;
    }

    .btn-details {
        background-color: #26c6da;
        color: white;
    }

    .btn-delete {
        background-color: #ef5350;
        color: white;
    }

        .btn-edit:hover,
        .btn-details:hover,
        .btn-delete:hover {
            opacity: 0.9;
            color: white;
        }

    /* BADGE DE ESTADO O PUNTUACIÓN */
    .score-badge {
        background-color: #0d47a1;
        color: white;
        padding: 5px 15px;
        border-radius: 15px;
        font-weight: bold;
    }
</style>

<div class="game-card text-center">
    <div class="title-capsule">
        🎮 Historial de Partidas
    </div>

    <div class="container mb-4">
        <form asp-action="Index" method="get">
            <div class="row justify-content-center">
                <div class="col-md-4">
                    <input type="text" name="buscarUsuario" value="@ViewData["FiltroUsuario"]"
                           class="form-control rounded-pill border-0 shadow-sm"
                           placeholder="🔍 Buscar por usuario..." />
                </div>
            
                <div class="col-md-3">
                    <select name="buscarEstado" class="form-select rounded-pill border-0 shadow-sm">
                        <option value="">Todos los estados</option>
                        <option value="Finalizada">Finalizada</option>
                        <option value="En Curso">En Curso</option>
                    </select>
                </div>

                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-primary rounded-pill px-4 shadow">Filtrar</button>
                    <a asp-action="Index" class="btn btn-light rounded-pill shadow-sm">Limpiar</a>
                </div>
            </div>
        </form>
    </div>

    <div class="search-container">
        <input type="text" id="searchInput" class="search-input" placeholder="Buscar por usuario o estado...">
    </div>

    <a asp-action="Create" class="btn-crear">➕ Nueva Partida</a>

    <div class="table-wrapper shadow">
        <table class="table align-middle" id="tablaPartidas">
            <thead>
                <tr>
                    <th>Puntuación Final</th>
                    <th>Fecha de Inicio</th>
                    <th>Estado</th>
                    <th>Modo de Juego</th>
                    <th>Usuario</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model) {
                    <tr>
                        <td>
                            <span class="score-badge">🏆 @Html.DisplayFor(modelItem => item.PuntuacionFinal)</span>
                        </td>
                        <td>📅 @item.FechaInicio.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>
                            <span class="badge @(item.Estado == "Terminado" ? "bg-success" : "bg-warning") text-white p-2">
                                @Html.DisplayFor(modelItem => item.Estado)
                            </span>
                        </td>
                        <td>🎮 @Html.DisplayFor(modelItem => item.ModoJuego)</td>
                        <td class="fw-bold">👤 @Html.DisplayFor(modelItem => item.Usuarios.Nombre)</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn-action btn-edit">✏️ Editar</a>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn-action btn-details">🔍 Detalles</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn-action btn-delete">🗑️ Eliminar</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById("searchInput").addEventListener("keyup", function () {
            let filter = this.value.toLowerCase();
            let rows = document.querySelectorAll("#tablaPartidas tbody tr");
            rows.forEach(row => {
                row.style.display = row.innerText.toLowerCase().includes(filter) ? "" : "none";
            });
        });
    </script>
}