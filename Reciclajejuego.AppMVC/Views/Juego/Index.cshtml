@model IEnumerable<Reciclajejuego.AppMVC.Models.Juego>

@{
    ViewData["Title"] = "Historial de Partidas";
}

<style>
    .main-container {
        min-height: 100vh;
    }

    .card-custom {
        background: #e1f5fe;
        border-radius: 30px;
        padding: 35px;
        max-width: 1200px;
        width: 100%;
        margin: auto;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }

    .titulo {
        background: linear-gradient(135deg, #36d1dc, #5b86e5);
        color: white;
        padding: 10px 30px;
        border-radius: 50px;
        font-size: 1.8rem;
        margin-bottom: 20px;
        display: inline-block;
    }

    .btn-crear {
        background: linear-gradient(135deg, #43e97b, #38c172);
        color: white;
        border-radius: 25px;
        padding: 10px 20px;
        text-decoration: none;
        font-weight: bold;
    }

    .btn-edit {
        background: linear-gradient(135deg, #f7971e, #f6a623);
        color: white;
        border-radius: 15px;
    }

    .btn-detail {
        background: linear-gradient(135deg, #36d1dc, #5b86e5);
        color: white;
        border-radius: 15px;
    }

    .btn-delete {
        background: linear-gradient(135deg, #ff5f6d, #ff7eb3);
        color: white;
        border-radius: 15px;
    }

    .table-wrapper {
        overflow-x: auto;
    }
</style>

<div class="container-fluid px-5 main-container d-flex justify-content-center align-items-center">

    <div class="card-custom text-center">

        <!-- TITULO -->
        <div class="mb-3">
            <span class="titulo">🎮 Historial de Partidas</span>
        </div>

        <!-- FILTRO -->
        <form asp-action="Index" method="get" class="mb-3">
            <div class="row g-2 justify-content-center">

                <div class="col-md-4">
                    <input type="text" name="buscarUsuario" value="@ViewData["FiltroUsuario"]"
                           class="form-control rounded-pill"
                           placeholder="🔍 Buscar por usuario..." />
                </div>

                <div class="col-md-3">
                    <select name="buscarEstado" class="form-select rounded-pill">
                        <option value="">Todos los estados</option>
                        <option value="Finalizada">Finalizada</option>
                        <option value="En Curso">En Curso</option>
                    </select>
                </div>

                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-primary rounded-pill">Filtrar</button>
                    <a asp-action="Index" class="btn btn-secondary rounded-pill">Limpiar</a>
                </div>

            </div>
        </form>

        <!-- BUSCADOR EN VIVO -->
        <div class="mb-3">
            <input type="text" id="searchInput" class="form-control rounded-pill"
                   placeholder="Buscar en la tabla...">
        </div>

        <!-- BOTÓN -->
        <div class="d-flex justify-content-end mb-3">
            <a asp-action="Create" class="btn-crear">➕ Nueva Partida</a>
        </div>

        <!-- TABLA -->
        <div class="table-wrapper shadow">
            <table class="table table-hover text-center align-middle mb-0" id="tablaPartidas">

                <thead>
                    <tr>
                        <th>Puntuación</th>
                        <th>Fecha</th>
                        <th>Estado</th>
                        <th>Modo</th>
                        <th>Usuario</th>
                        <th>Acciones</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>🏆 @item.PuntuacionFinal</td>
                            <td>📅 @item.FechaInicio.ToString("dd/MM/yyyy HH:mm")</td>

                            <td>
                                <span class="badge @(item.Estado == "Terminado" ? "bg-success" : "bg-warning")">
                                    @item.Estado
                                </span>
                            </td>

                            <td>🎮 @item.ModoJuego</td>
                            <td class="fw-bold">👤 @item.Usuarios.Nombre</td>

                            <td>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-edit me-1">Editar</a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-detail me-1">Detalles</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-delete">Eliminar</a>
                            </td>
                        </tr>
                    }
                </tbody>

            </table>
        </div>

    </div>

</div>

@section Scripts {
    <script>
        document.getElementById("searchInput").addEventListener("keyup", function () {
            let filter = this.value.toLowerCase();
            let rows = document.querySelectorAll("#tablaPartidas tbody tr");

            rows.forEach(row => {
                row.style.display = row.innerText.toLowerCase().includes(filter) ? "" : "none";
            });
        });
    </script>
}