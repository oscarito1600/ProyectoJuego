@model IEnumerable<Reciclajejuego.AppMVC.Models.DetallesModo>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Vidas)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.TiempoLimite)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ComboMaximo)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ModoJuego)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Vidas)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.TiempoLimite)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ComboMaximo)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ModoJuego.Id)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.ModoJuegoId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.ModoJuegoId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.ModoJuegoId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
