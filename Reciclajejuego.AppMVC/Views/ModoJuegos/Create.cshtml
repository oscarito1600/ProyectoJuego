@model Reciclajejuego.AppMVC.Models.ModoJuegos

@{
    ViewData["Title"] = "Crear Modo de Juego";
}

<div class="container mt-5">
    <div class="card-eco p-4" style="max-width:500px; margin:auto; border-radius:15px; box-shadow:0 10px 30px rgba(0,0,0,0.1);">
        <h2 class="text-center mb-3">🎮 Crear Nuevo Modo de Juego</h2>

        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Nombre" class="form-label"></label>
                <input asp-for="Nombre" class="form-control" />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>

            <div class="d-flex justify-content-between mt-3">
                <a asp-action="Index" class="btn btn-secondary">⬅ Volver</a>
                <input type="submit" value="Crear 🎯" class="btn btn-success" />
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}