@model Reciclajejuego.AppMVC.Models.ModoJuego

@{
    ViewData["Title"] = "Eliminar Modo de Juego";
}

<style>
    .main-container {
        min-height: 100vh;
    }

    .card-custom {
        background: #e1f5fe;
        border-radius: 30px;
        padding: 35px;
        max-width: 800px; /* 🔥 MÁS ANCHO */
        width: 100%;
        margin: auto;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }

    .titulo {
        background: linear-gradient(135deg, #ff4d4d,#ff4d4d);
        color: white;
        padding: 12px;
        border-radius: 50px;
        text-align: center;
        font-weight: bold;
        margin-bottom: 20px;
        font-size: 1.5rem;
    }

    .alerta {
        background: #ffe5e5;
        color: #c62828;
        padding: 15px;
        border-radius: 20px;
        text-align: center;
        font-weight: bold;
        margin-bottom: 20px;
    }

    .detalle-box {
        background: white;
        border-radius: 20px;
        padding: 25px;
        margin-bottom: 25px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        text-align: center;
    }

    .detalle-label {
        color: #5b86e5;
        font-size: 1rem;
        display: block;
        margin-bottom: 5px;
    }

    .detalle-valor {
        font-size: 1.6rem;
        font-weight: bold;
        color: #333;
    }

    .botones {
        display: flex;
        gap: 10px;
    }

    .btn-eliminar {
        background: linear-gradient(135deg, #ff4d4d,#ff4d4d);
        color: white;
        border-radius: 25px;
        padding: 12px;
        width: 50%;
        border: none;
        font-weight: bold;
    }

    .btn-volver {
        background: linear-gradient(135deg, #90a4ae, #607d8b);
        color: white;
        border-radius: 25px;
        padding: 12px;
        width: 50%;
        text-align: center;
        text-decoration: none;
        font-weight: bold;
    }

        .btn-eliminar:hover,
        .btn-volver:hover {
            opacity: 0.9;
            color: white;
        }
</style>

<div class="container-fluid px-4 main-container d-flex justify-content-center align-items-center">

    ```
    <div class="card-custom">

        <div class="titulo">
            🗑️ Eliminar Modo de Juego
        </div>

        <div class="alerta">
            ⚠️ Esta acción no se puede deshacer
        </div>

        <div class="detalle-box">
            <span class="detalle-label">Nombre</span>
            <span class="detalle-valor">@Model.Nombre</span>
        </div>

        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />

            <div class="botones">
                <button type="submit" class="btn-eliminar">
                    ❌ Confirmar eliminación
                </button>

                <a asp-action="Index" class="btn-volver">
                    ⬅️ Cancelar
                </a>
            </div>
        </form>

    </div>
    ```

</div>

