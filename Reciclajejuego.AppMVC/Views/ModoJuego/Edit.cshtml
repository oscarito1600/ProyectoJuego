@model Reciclajejuego.AppMVC.Models.ModoJuego

@{
    ViewData["Title"] = "Editar Modo de Juego";
}

<style>
    body {
        background: linear-gradient(135deg, #66bb6a, #a5d6a7);
        min-height: 100vh;
    }

    .contenedor {
        max-width: 500px;
        margin: auto;
        margin-top: 50px;
    }

    .card-custom {
        background: #e3f2fd;
        border-radius: 20px;
        padding: 30px;
        box-shadow: 0px 8px 25px rgba(0,0,0,0.2);
    }

    .titulo {
        background: #0d47a1;
        color: white;
        padding: 12px;
        border-radius: 12px;
        text-align: center;
        font-weight: bold;
        margin-bottom: 25px;
    }

    .form-control {
        border-radius: 10px;
    }

    .btn-guardar {
        background: #1565c0;
        color: white;
        border-radius: 20px;
        padding: 10px;
        width: 100%;
        border: none;
        font-weight: bold;
        margin-bottom: 10px;
    }

        .btn-guardar:hover {
            background: #0d47a1;
        }

    .btn-volver {
        background: #90a4ae;
        color: white;
        border-radius: 20px;
        padding: 10px;
        width: 100%;
        text-align: center;
        display: inline-block;
        text-decoration: none;
        font-weight: bold;
    }

        .btn-volver:hover {
            background: #607d8b;
        }
</style>

<div class="contenedor">
    <div class="card-custom">

        <div class="titulo">
            ✏️ Editar Modo de Juego
        </div>

        <form asp-action="Edit">

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label asp-for="Nombre" class="form-label fw-bold"></label>
                <input asp-for="Nombre" class="form-control" />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>

            <button type="submit" class="btn-guardar">
                💾 Guardar Cambios
            </button>

            <a asp-action="Index" class="btn-volver">
                ⬅️ Volver
            </a>

        </form>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}