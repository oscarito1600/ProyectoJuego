@model IEnumerable<Reciclajejuego.AppMVC.Models.ModoJuego>

@{
    ViewData["Title"] = "Modos de Juego";
}

<style>
    .main-container {
        min-height: 100vh;
    }

    .card-custom {
        background: #e1f5fe;
        border-radius: 30px;
        padding: 35px;
        max-width: 1200px; /* 🔥 MÁS ANCHO */
        width: 100%;
        margin: auto;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }

    .titulo {
        background: linear-gradient(135deg, #36d1dc, #5b86e5);
        color: white;
        padding: 10px 30px;
        border-radius: 50px;
        font-size: 1.8rem;
        margin-bottom: 20px;
        display: inline-block;
    }

    .btn-crear {
        background: linear-gradient(135deg, #43e97b, #38c172);
        color: white;
        border-radius: 25px;
        padding: 10px 20px;
        text-decoration: none;
        font-weight: bold;
    }

    .btn-editar {
        background: linear-gradient(135deg, #f6a623, #f7971e);
        color: white;
        border-radius: 15px;
    }

    .btn-detalles {
        background: linear-gradient(135deg, #36d1dc, #5b86e5);
        color: white;
        border-radius: 15px;
    }

    .btn-eliminar {
        background: linear-gradient(135deg, #ff5f6d, #ff7eb3);
        color: white;
        border-radius: 15px;
    }

    .table-wrapper {
        overflow-x: auto; /* 🔥 EVITA QUE SE AMONTONE */
    }
</style>

<div class="container-fluid px-5 main-container d-flex justify-content-center align-items-center">

    ```
    <div class="card-custom text-center">

        <div class="mb-3">
            <span class="titulo">🎮 Modos de Juego</span>
        </div>

        <!-- FILTRO -->
        <form asp-action="Index" method="get" class="mb-3">
            <div class="row g-2 justify-content-center">
                <div class="col-md-6">
                    <input type="text" name="buscar" value="@ViewBag.Buscar"
                           class="form-control rounded-pill"
                           placeholder="Buscar modo..." />
                </div>
                <div class="col-md-2 d-grid">
                    <button type="submit" class="btn btn-primary rounded-pill">Buscar</button>
                </div>
                <div class="col-md-2 d-grid">
                    <a asp-action="Index" class="btn btn-secondary rounded-pill">Limpiar</a>
                </div>
            </div>
        </form>

        <!-- BOTÓN -->
        <div class="d-flex justify-content-end mb-3">
            <a asp-action="Create" class="btn-crear">➕ Crear</a>
        </div>

        <!-- TABLA -->
        <div class="table-wrapper shadow">
            <table class="table table-hover text-center align-middle mb-0">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th style="width: 300px;">Acciones</th> <!-- 🔥 MÁS ESPACIO -->
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold">@item.Nombre</td>

                            <td>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-editar me-1">Editar</a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-detalles me-1">Detalles</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-eliminar">Eliminar</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- PAGINACIÓN -->
        <div class="d-flex justify-content-center mt-4">
            @for (int i = 1; i <= ViewBag.TotalPaginas; i++)
            {
                <a asp-action="Index"
                       asp-route-pagina="@i"
                       asp-route-buscar="@ViewBag.Buscar"
                       class="btn btn-sm @(i == ViewBag.PaginaActual ? "btn-primary" : "btn-light") mx-1">
                    @i
                </a>
            }
        </div>

    </div>
    ```

</div>


