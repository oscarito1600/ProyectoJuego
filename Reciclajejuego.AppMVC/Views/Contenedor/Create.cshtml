@model Reciclajejuego.AppMVC.Models.Contenedor


@{
    ViewData["Title"] = "Crear Contenedor";
}

<style>
    /* FONDO VERDE SÓLIDO  */
    body {
        background-color: #2ecc71 !important; 
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0;
    }

    /* TARJETA BLANCA */
    .game-card {
        background: white;
        border-radius: 30px;
        padding: 40px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.2);
        width: 100%;
        max-width: 600px;
    }

    .titulo-eco {
        color: #1b5e20;
        font-weight: 800;
        text-align: center;
    }

    /* BOTÓN CREAR  */
    .btn-crear-pill {
        background-color: #5cb85c !important;
        color: white !important;
        border: none !important;
        border-radius: 50px !important;
        padding: 12px 30px !important;
        font-weight: bold;
        transition: all 0.3s ease;
    }

    .btn-crear-pill:hover {
        background-color: #4cae4c !important;
        transform: scale(1.05);
    }

    /* BOTÓN VOLVER (AZUL) */
    .btn-volver-pill {
        background-color: #00aeef !important;
        color: white !important;
        border: none !important;
        border-radius: 50px !important;
        padding: 12px 30px !important;
        font-weight: bold;
        text-decoration: none;
    }

    /* AJUSTE PARA EL INPUT DE COLOR */
    .form-control-color {
        height: 50px;
        width: 100%;
        border-radius: 20px !important;
        cursor: pointer;
    }
</style>

<div class="container d-flex justify-content-center">
    <div class="game-card">
        
        <h2 class="titulo-eco mb-4">
            ♻️ Crear Nuevo Contenedor
        </h2>

        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-4">
                <label asp-for="TipoReciclaje" class="form-label fw-bold" style="color: #2e7d32;">Tipo de Reciclaje</label>
                <input asp-for="TipoReciclaje" class="form-control rounded-pill border-2" style="border-color: #2dce89;" placeholder="Ej: Plástico, Vidrio..." />
                <span asp-validation-for="TipoReciclaje" class="text-danger"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Color" class="form-label fw-bold" style="color: #2e7d32;">Color del Contenedor</label>
                <input asp-for="Color" class="form-control form-control-color border-2" style="border-color: #2dce89;" type="color" />
                <span asp-validation-for="Color" class="text-danger"></span>
            </div>

            <div class="d-flex justify-content-between mt-5">
                <a asp-action="Index" class="btn btn-volver-pill shadow-sm">
                   ⬅ Volver
                </a>
                
                <button type="submit" class="btn btn-crear-pill shadow">
                    🌱 Crear Contenedor
                </button>
            </div>
        </form>

    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}