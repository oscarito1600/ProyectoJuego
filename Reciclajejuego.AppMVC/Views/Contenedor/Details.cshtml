@model Reciclajejuego.AppMVC.Models.Contenedor

@{
    ViewData["Title"] = "Detalles del Contenedor";
}

<style>
    body {
        background: linear-gradient(135deg, #e3f2fd, #e8f5e9);
    }

    .card-eco {
        background: white;
        padding: 35px;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        max-width: 650px;
        margin: auto;
    }

    .titulo {
        text-align: center;
        font-weight: bold;
        color: #1b5e20;
    }

    dt {
        font-weight: bold;
        color: #2e7d32;
    }

    .color-box {
        height: 60px;
        border-radius: 15px;
        border: 1px solid #ccc;
        margin-top: 10px;
    }

    .btn-editar {
        background-color: #0288d1;
        color: white;
        padding: 8px 18px;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 600;
    }

        .btn-editar:hover {
            background-color: #01579b;
            color: white;
        }

    .btn-volver {
        background-color: #43a047;
        color: white;
        padding: 8px 18px;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 600;
    }

        .btn-volver:hover {
            background-color: #1b5e20;
            color: white;
        }
</style>

<div class="container mt-5">
    <div class="card-eco">

        <h2 class="titulo mb-4">🔍 Detalles del Contenedor</h2>

        <dl class="row">
            <dt class="col-sm-4">
                @Html.DisplayNameFor(model => model.TipoReciclaje)
            </dt>
            <dd class="col-sm-8">
                🌱 @Html.DisplayFor(model => model.TipoReciclaje)
            </dd>

            <dt class="col-sm-4">
                @Html.DisplayNameFor(model => model.Color)
            </dt>
            <dd class="col-sm-8">
                @Html.DisplayFor(model => model.Color)

                <div class="color-box" style="background-color:@Model.Color"></div>
            </dd>
        </dl>

        <div class="d-flex justify-content-between mt-4">
            <a asp-action="Index" class="btn-volver">⬅ Volver</a>
            <a asp-action="Edit" asp-route-id="@Model?.ContenedorId" class="btn-editar">
                ✏ Editar
            </a>
        </div>

    </div>
</div>