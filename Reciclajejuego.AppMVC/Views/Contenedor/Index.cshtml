@model IEnumerable<Reciclajejuego.AppMVC.Models.Contenedor>

@{
    ViewData["Title"] = "Gestión de Contenedores";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<style>

    /* FONDO */
    body {
        background-color: #2e7d32;
        min-height: 100vh;
        font-family: 'Segoe UI', sans-serif;
    }

    /* CONTENEDOR */
    .main-container {
        min-height: 100vh;
    }

    /* TARJETA */
    .game-card {
        background-color: #b3e5fc;
        border-radius: 30px;
        padding: 40px;
        max-width: 1100px;
        width: 100%;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }

    /* TÍTULO */
    .title-capsule {
        background-color: #0d47a1;
        color: white;
        padding: 10px 40px;
        border-radius: 50px;
        font-size: 2rem;
        font-weight: bold;
        display: inline-block;
    }

    /* BUSCADOR */
    .search-input {
        border-radius: 30px;
        border: 2px solid #0d47a1;
    }

    /* TABLA */
    .table-wrapper {
        background-color: #e1f5fe;
        border: 3px solid #0288d1;
        border-radius: 20px;
        overflow: hidden;
    }

    /* ENCABEZADO */
    .table thead th {
        background-color: #b3e5fc;
        color: #01579b;
        text-align: center;
    }

    /* FILAS */
    .table tbody td {
        background-color: #e1f5fe;
        color: #37474f;
    }

    /* BOTONES */
    .btn-edit {
        background-color: #ffa000;
        color: white;
    }

    .btn-details {
        background-color: #26c6da;
        color: white;
    }

    .btn-delete {
        background-color: #ef5350;
        color: white;
    }

        .btn-edit:hover,
        .btn-details:hover,
        .btn-delete:hover {
            opacity: 0.9;
            color: white;
        }

</style>

<!-- CONTENIDO -->
<div class="container-fluid d-flex justify-content-center align-items-center main-container">

    <div class="game-card">

        <!-- TÍTULO -->
        <<div class="text-center mb-4">
            <span class="title-capsule">Contenedores Registrados</span>
        </div>

        <!-- BUSCADOR -->
        <div class="row mb-3">
            <div class="col-md-6 mx-auto">
                <input type="text" class="form-control search-input" placeholder="Buscar...">
            </div>
        </div>

        <form asp-action="Index" method="get" class="mb-4">
            <div class="row">
                <div class="col-md-4">
                    <input type="text" name="buscarNombre" value="@ViewData["FiltroNombre"]"
                           class="form-control" placeholder="Buscar por tipo (hojas, vidrio...)" />
                </div>
                <div class="col-md-4">
                    <input type="text" name="buscarColor" value="@ViewData["FiltroColor"]"
                           class="form-control" placeholder="Buscar por color (hex)..." />
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary">Buscar</button>
                </div>
                <div class="col-md-2">
                    <a asp-action="Index" class="btn btn-secondary">Limpiar</a>
                </div>
            </div>
        </form>

        <!-- BOTÓN CREAR -->
        <div class="d-flex justify-content-end mb-3">
            <a asp-action="Create" class="btn btn-primary rounded-pill px-4">+ Crear</a>
        </div>

        <!-- TABLA -->
        <div class="table-wrapper">
            <table class="table mb-0 text-center align-middle">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Tipo de Reciclaje</th>
                        <th>Color</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>

                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td>@item.TipoReciclaje</td>
                            <td>
                                <span style="display:inline-block; width:20px; height:20px; background-color:@item.Color; border-radius:5px;"></span>
                                @item.Color
                            </td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-edit">Editar</a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-details">Detalles</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-delete">Eliminar</a>
                            </td>
                        </tr>
                    }

                </tbody>
            </table>
        </div>

    </div>

</div>