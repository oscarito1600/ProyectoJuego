@model IEnumerable<Reciclajejuego.AppMVC.Models.Contenedor>

@{
    ViewData["Title"] = "Gestión de Contenedores";
}

<style>

    /* CONTENEDOR PRINCIPAL */
    .main-container {
        min-height: 100vh;
    }

    /* TARJETA */
    .game-card {
        background-color: #e1f5fe;
        border-radius: 30px;
        padding: 40px;
        max-width: 1100px;
        width: 100%;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }

    /* TÍTULO */
    .title-capsule {
        background: linear-gradient(135deg, #36d1dc, #5b86e5);
        color: white;
        padding: 10px 40px;
        border-radius: 50px;
        font-size: 2rem;
        font-weight: bold;
        display: inline-block;
    }

    /* INPUTS */
    .form-control {
        border-radius: 20px;
    }

    .search-input {
        border-radius: 30px;
        border: 2px solid #5b86e5;
    }

    /* WRAPPER TABLA */
    .table-wrapper {
        border-radius: 20px;
        overflow: hidden;
    }

    /* BOTONES TABLA */
    .btn-edit {
        background: linear-gradient(135deg, #f6a623, #f7971e);
        color: white;
        border-radius: 20px;
    }

    .btn-details {
        background: linear-gradient(135deg, #36d1dc, #5b86e5);
        color: white;
        border-radius: 20px;
    }

    .btn-delete {
        background: linear-gradient(135deg, #ff5f6d, #ff7eb3);
        color: white;
        border-radius: 20px;
    }

        .btn-edit:hover,
        .btn-details:hover,
        .btn-delete:hover {
            opacity: 0.9;
            color: white;
        }

    /* BOTÓN CREAR */
    .btn-crear-custom {
        background: linear-gradient(135deg, #90a4ae, #607d8b);
        color: white;
        border-radius: 25px;
        padding: 12px;
        width: 100%;
        text-align: center;
        text-decoration: none;
        font-weight: bold;
        transition: 0.3s;
    }

        .btn-crear-custom:hover, 
.btn-guardar:hover, 
.btn-volver:hover {
    transform: scale(1.03);
    color: white;
}
            

        </style>


<div class="container-fluid d-flex justify-content-center align-items-center main-container">

    <div class="game-card">

        <!-- TÍTULO -->
        <div class="text-center mb-4">
            <span class="title-capsule">Contenedores Registrados</span>
        </div>

        <!-- BUSCADOR SIMPLE -->
        <div class="row mb-3">
            <div class="col-md-6 mx-auto">
                <input type="text" class="form-control search-input" placeholder="Buscar...">
            </div>
        </div>

        <!-- FILTROS -->
        <form asp-action="Index" method="get" class="mb-4">
            <div class="row g-2">
                <div class="col-md-4">
                    <input type="text" name="buscarNombre" value="@ViewData["FiltroNombre"]"
                           class="form-control" placeholder="Tipo (hojas, vidrio...)" />
                </div>
                <div class="col-md-4">
                    <input type="text" name="buscarColor" value="@ViewData["FiltroColor"]"
                           class="form-control" placeholder="Color (hex...)" />
                </div>
                <div class="col-md-2 d-grid">
                    <button type="submit" class="btn btn-primary rounded-pill">Buscar</button>
                </div>
                <div class="col-md-2 d-grid">
                    <a asp-action="Index" class="btn btn-secondary rounded-pill">Limpiar</a>
                </div>
            </div>
        </form>

        <form asp-action="Create" method="post">

            <div class="d-flex justify-content-end mt-3">
                <button type="submit" class="btn btn-success rounded-pill shadow-sm px-4 py-2 border-0 d-flex align-items-center">
                    <span class="me-2">🌱</span> Crear Nuevo Contenedor
                </button>
            </div>

        </form>

        <!-- TABLA -->
        <div class="table-wrapper">
            <table class="table table-hover mb-0 text-center align-middle">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Tipo de Reciclaje</th>
                        <th>Color</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>

                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td>@item.TipoReciclaje</td>
                            <td>
                                <span style="display:inline-block; width:20px; height:20px; background-color:@item.Color; border-radius:5px;"></span>
                                @item.Color
                            </td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-edit">Editar</a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-details">Detalles</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-delete">Eliminar</a>
                            </td>
                        </tr>
                    }

                </tbody>
            </table>
        </div>

    </div>

</div>