@model Reciclajejuego.AppMVC.Models.Contenedor

@{
    ViewData["Title"] = "Editar Contenedor";
}

<style>
    body {
        background-color: #2e7d32;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Segoe UI', sans-serif;
    }

    .game-card {
        background-color: #ffffff; /* Fondo blanco para el formulario */
        border-radius: 30px;
        padding: 40px;
        width: 100%;
        max-width: 600px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.3);
    }

    .title-capsule {
        color: #2e7d32;
        font-size: 2.2rem;
        font-weight: bold;
        margin-bottom: 30px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 15px;
    }

    .form-label {
        color: #2e7d32;
        font-weight: bold;
        font-size: 1.1rem;
    }

    .form-control {
        border: 2px solid #2e7d32;
        border-radius: 10px;
        padding: 12px;
        margin-bottom: 20px;
    }

    .btn-container {
        display: flex;
        justify-content: space-between;
        margin-top: 20px;
    }

    .btn-save {
        background-color: #4caf50;
        color: white;
        border: none;
        padding: 10px 25px;
        border-radius: 10px;
        font-weight: bold;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .btn-back {
        background-color: #0288d1;
        color: white;
        border: none;
        padding: 10px 25px;
        border-radius: 10px;
        font-weight: bold;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .btn-save:hover, .btn-back:hover {
            opacity: 0.9;
            color: white;
        }
</style>

<div class="game-card">
    <div class="title-capsule">
        🗑️ Editar Contenedor
    </div>

    <form asp-action="Edit">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        
        <input type="hidden" asp-for="Id" />

        <div class="form-group">
            <label asp-for="TipoReciclaje" class="form-label">Tipo de Reciclaje</label>
            <input asp-for="TipoReciclaje" class="form-control" placeholder="Ej: Botellas, Papel..." />
            <span asp-validation-for="TipoReciclaje" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Color" class="form-label">Color del Contenedor</label>
            <input asp-for="Color" type="color" class="form-control form-control-color w-100" style="height: 50px;" />
            <span asp-validation-for="Color" class="text-danger"></span>
        </div>

        <div class="btn-container">
            <a asp-action="Index" class="btn-back">
                ⬅️ Volver
            </a>
            <button type="submit" class="btn-save">
                💾 Guardar Cambios
            </button>
        </div>
    </form>
</div>