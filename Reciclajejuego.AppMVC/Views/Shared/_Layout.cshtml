<!DOCTYPE html>

<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Reciclaje Juego</title>


<!-- Bootstrap (solo uno) -->
<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

<!-- Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

<style>
    body {
        background: #2ecc71;
    }

    /* NAVBAR */
    .navbar {
        background: transparent !important;
        border: none;
    }

    /* MENU */
    .menu-app {
        padding: 20px;
    }

    /* BOTONES MENU */
    .btn-app {
        display: flex;
        align-items: center;
        gap: 20px;
        width: 100%;
        padding: 20px;
        margin-bottom: 20px;
        border-radius: 25px;
        color: white;
        text-decoration: none;
        font-size: 22px;
        font-weight: 500;
        box-shadow: 0 8px 15px rgba(0,0,0,0.2);
        transition: all 0.2s ease;
    }

    .btn-app i {
        font-size: 30px;
    }

    .btn-app:hover {
        transform: scale(1.03);
        color: white;
    }

    /* COLORES */
    .azul { background: linear-gradient(135deg, #4facfe, #4a6cf7); }
    .morado { background: linear-gradient(135deg, #7b5cff, #a18cd1); }
    .verde { background: linear-gradient(135deg, #43e97b, #38c172); }
    .naranja { background: linear-gradient(135deg, #f7971e, #f6a623); }
    .rosado { background: linear-gradient(135deg, #ff5f6d, #ff7eb3); }
    .celeste { background: linear-gradient(135deg, #36d1dc, #5b86e5); }
    .morado2 { background: linear-gradient(135deg, #667eea, #a18cd1); }
    .turquesa { background: linear-gradient(135deg, #2bc0e4, #43e97b); }

    /* OFFCANVAS */
    .offcanvas {
        width: 350px;
        background: #f8f9fa;
        border-radius: 0 25px 25px 0;
    }

    /* CONTENEDOR */
    .container, main {
        background: transparent !important;
    }

    /* ===================== */
    /* ESTILO GLOBAL TABLAS  */
    /* ===================== */

    .table {
        border-radius: 15px;
        overflow: hidden;
        background: white;
        box-shadow: 0 8px 15px rgba(0,0,0,0.1);
    }

    .table thead {
        background: linear-gradient(135deg, #36d1dc, #5b86e5);
        color: white;
        text-align: center;
    }

    .table tbody tr:nth-child(even) {
        background-color: #f2faff;
    }

    .table tbody tr:hover {
        background-color: #d6eeff;
        transition: 0.3s;
    }

    .table th, .table td {
        padding: 12px;
        text-align: center;
        vertical-align: middle;
    }

    /* BOTONES TABLAS */
    .btn-editar {
        background-color: #a18cd1;
        color: white;
        border-radius: 10px;
    }

    .btn-detalles {
        background-color: #f6a623;
        color: white;
        border-radius: 10px;
    }

    .btn-eliminar {
        background-color: #ff7eb3;
        color: white;
        border-radius: 10px;
    }
</style>


</head>

<body>


<!-- NAVBAR -->
<header>
    <nav class="navbar navbar-light">
        <div class="container-fluid">

            <button class="btn btn-light" type="button" data-bs-toggle="offcanvas" data-bs-target="#menuLateral">
                ☰
            </button>

            <span class="navbar-brand mb-0 h1 text-white">
             
            </span>

        </div>
    </nav>
</header>

<!-- MENU LATERAL -->
<div class="offcanvas offcanvas-start" tabindex="-1" id="menuLateral">

    <div class="offcanvas-header">
        <h5 class="offcanvas-title">Menú</h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
    </div>

    <div class="offcanvas-body menu-app">

        <a class="btn-app azul" asp-controller="Home" asp-action="Index">
            <i class="bi bi-house"></i>
            <span>Inicio</span>
        </a>

        <a class="btn-app morado" asp-controller="Usuarios" asp-action="Index">
            <i class="bi bi-person"></i>
            <span>Usuarios</span>
        </a>

        <a class="btn-app verde" asp-controller="Residuos" asp-action="Index">
            <i class="bi bi-recycle"></i>
            <span>Residuos</span>
        </a>

         <a class="btn-app turquesa" asp-controller="PantallaMenu" asp-action="Index">
            <i class="bi bi-controller"></i>
            <span>Games</span>
        </a>

        <a class="btn-app naranja" asp-controller="Contenedor" asp-action="Index">
            <i class="bi bi-trash3"></i>
            <span>Contenedores</span>
        </a>

        <a class="btn-app rosado" asp-controller="Juego" asp-action="Index">
            <i class="bi bi-geo-alt"></i>
            <span>Partidas</span>
        </a>

        <a class="btn-app celeste" asp-controller="ModoJuego" asp-action="Index">
            <i class="bi bi-grid"></i>
            <span>Modos</span>
        </a>

        <a class="btn-app morado2" asp-controller="Ajustes" asp-action="Index">
            <i class="bi bi-gear"></i>
            <span>Ajustes</span>
        </a>

        <a class="btn-app turquesa" asp-controller="Roles" asp-action="Index">
            <i class="bi bi-people"></i>
            <span>Roles</span>
        </a>

    </div>

</div>

<!-- CONTENIDO -->
<div class="container">
    <main role="main">
        @RenderBody()
    </main>
</div>

<!-- SCRIPTS -->
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

@await RenderSectionAsync("Scripts", required: false)
```

</body>
</html>

